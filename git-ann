#!/usr/bin/env bash

test -n "$DEBUG" && set -x

set -euo pipefail

# ============================================================================
# Configuração
# ============================================================================

readonly MAX_ITERATIONS=100  # segurança contra loop infinito

# ============================================================================
# Helpers
# ============================================================================

# Conta quantos arquivos ainda têm pendências (excluindo conflitos)
count_actionable() {
    git status --porcelain \
        | grep -v '^[UAD][UAD]' \
        | grep -c '[^ ]' \
        || true
}

has_conflicts() {
    git status --porcelain \
        | grep -qE '^(UU|AA|DD|DU|UD|UA|AU)' \
        || false
}

# ============================================================================
# Entry point
# ============================================================================

cd "$(git rev-parse --show-toplevel)"

# Verifica conflitos antes de começar
if has_conflicts; then
    echo -e "\e[1;31m❗ Existem conflitos não resolvidos.\e[0m"
    echo -e "Resolva-os antes de rodar git-ann:"
    git status --short | grep -E '^(UU|AA|DD|DU|UD|UA|AU)'
    exit 1
fi

iterations=0

while true; do
    # Limite de segurança
    if (( iterations >= MAX_ITERATIONS )); then
        echo -e "\e[1;31m❗ Limite de $MAX_ITERATIONS iterações atingido.\e[0m"
        echo -e "Verifique o repositório manualmente."
        exit 1
    fi

    # Para o loop se não houver mais nada para commitar
    if [[ -z "$(git status --porcelain)" ]]; then
        echo ""
        echo -e "\e[1;32m✓ Repositório limpo — todos os arquivos foram commitados.\e[0m"
        git log --oneline -5
        break
    fi

    # Se surgirem conflitos durante o loop, para imediatamente
    if has_conflicts; then
        echo -e "\e[1;31m❗ Conflito detectado durante o loop — interrompendo.\e[0m"
        git status --short
        exit 1
    fi

    git an || break

    (( iterations++ ))
done

exit 0
