##############################################################################
##############################################################################
##############################################################################
BOLD=$(tput bold)
RESET=$(tput sgr0)

# Cores e marcadores visuais
CHEKED='\e[1;49;92m[✓]\t\e[0m'
STAGED='\e[1;49;36mStaged\e[0m'
UNTRACKED='\e[7;41;90mUntracked\e[0m'
UNMODIFIED='\e[1;49;92mUnmodified\e[0m'
MODIFIED='\e[1;49;33mModified\e[0m'
DELETED='\e[1;44;36mDeleted from project\e[0m'
REMOVED='\e[1;39;106mRemoved\e[0m'
LR='\e[38;5;33mLocal Repository\e[0m'
WD='\e[1;39;1mWorking directory\e[0m'

# Função principal
add_manager() {
    git status --porcelain |
        sed -r \
            -e 's/\s/@/g' \
            -e 's/@\->@/ ➜ /g' \
            -e 's/(^..)(.*)/\1;\2/' |
        while IFS=';' read state file; do

            file=${file#@}
            case x${state} in
                x\?\?)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $UNTRACKED \> $STAGED
                    echo \$ git add $file
                    git add "$file"
                    echo \$ git commit -m "➕ :add: Adiciona o arquivo $file"
                    git commit -m "➕ :add: Adiciona o arquivo $file"
                    ;;

                xA@)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $STAGED \> $LR
                    echo \$ git commit -m "➕ :add: Adiciona o arquivo $file"
                    git commit -m "➕ :add: Adiciona o arquivo $file"
                    ;;

                xAM)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $STAGED \> $LR
                    echo \$ git commit -m "🐛 :fix: Primeira revisão do arquivo $file"
                    git commit -m "🐛 :fix: Primeira revisão do arquivo $file"
                    ;;

                x@M)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $WD \> $STAGED
                    git add "$file"
                    echo \$ git commit -m "🎨 :style: Atualiza o estilo do arquivo $file"
                    git commit -m "🎨 :style: Atualiza o estilo do arquivo $file"
                    ;;

                xM@)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $STAGED \> $LR
                    echo \$ git commit -m "♻️ :refactor: Refatora o arquivo $file"
                    git commit -m "♻️ :refactor: Refatora o arquivo $file"
                    ;;

                x@D)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $WD \> $STAGED
                    git add "$file"
                    echo \$ git commit -m "⚠️ :warning: Arquivo $file marcado para deleção"
                    git commit -m "⚠️ :warning: Arquivo $file marcado para deleção"
                    ;;

                xD@)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $STAGED \> $DELETED
                    echo \$ git commit -m "➖ :remove: Remove o arquivo $file"
                    git commit -m "➖ :remove: Remove o arquivo $file"
                    ;;

                x@R)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $WD \> $STAGED
                    git add "$file"
                    echo \$ git commit -m "🔧 :chore: Prepara renomeação de $file"
                    git commit -m "🔧 :chore: Prepara renomeação de $file"
                    ;;

                xR@)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $STAGED \> $LR
                    echo \$ git commit -m "✏️ :rename: Renomeia o arquivo $file"
                    git commit -m "✏️ :rename: Renomeia o arquivo $file"
                    ;;

                xRM)
                    echo -e File:\`$BOLD${file}$RESET\'
                    echo -e $STAGED \> $LR
                    echo \$ git commit -m "♻️ :refactor: Renomeia e modifica $file"
                    git commit -m "♻️ :refactor: Renomeia e modifica $file"
                    ;;

                *)
                    echo -e "⚠️ Estado desconhecido: $state para arquivo $file"
                    ;;
            esac

        done
}

# Run!
if ! [[ $(git status --porcelain) ]]; then
    #no changes
    git status --short --branch
    false
else
    # changes
    add_manager
    true
fi

# ----------------------------------------------------------------------------
exit 0
